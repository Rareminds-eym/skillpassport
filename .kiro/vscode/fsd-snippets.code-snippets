  "FSD Entity Card Component": {
    "prefix": "fsd-entity-card",
    "body": [
      "import type { ${1:EntityName} } from '../model';",
      "",
      "export interface ${1:EntityName}CardProps {",
      "  entity: ${1:EntityName};",
      "  onClick?: (entity: ${1:EntityName}) => void;",
      "}",
      "",
      "export function ${1:EntityName}Card({ entity, onClick }: ${1:EntityName}CardProps) {",
      "  return (",
      "    <div ",
