      " * Dependencies:",
      " * - Entities: ${2:list entities}",
      " * - Features: ${3:list features}",
      " * - Shared: ${4:list shared components}",
      " */",
      "export function ${1:WidgetName}({ className }: ${1:WidgetName}Props) {",
      "  return (",
      "    <div className={className}>",
