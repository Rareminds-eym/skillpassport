    "prefix": "fsd-widget-store",
    "body": [
      "import { create } from 'zustand';",
      "import type { ${1:WidgetName}State } from './types';",
      "",
      "interface ${1:WidgetName}Store extends ${1:WidgetName}State {",
      "  setLoading: (isLoading: boolean) => void;",
      "  $0",
      "}",
      "",
      "export const use${1:WidgetName}Store = create<${1:WidgetName}Store>((set) => ({",
      "  isLoading: false,",
      "  setLoading: (isLoading) => set({ isLoading }),",
