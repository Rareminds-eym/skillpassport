  "FSD Entity Validation": {
    "prefix": "fsd-entity-validation",
    "body": [
      "import type { ${1:EntityName} } from './types';",
      "",
      "export function validate${1:EntityName}(data: unknown): data is ${1:EntityName} {",
      "  if (!data || typeof data !== 'object') return false;",
      "  const entity = data as Record<string, unknown>;",
      "  return (",
      "    typeof entity.id === 'string' &&",
      "    typeof entity.createdAt === 'string' &&",
      "    typeof entity.updatedAt === 'string'",
      "    $0",
      "  );",
      "}"
    ],
    "description": "Create FSD entity validation function"
  },
  "FSD Entity Utils": {
    "prefix": "fsd-entity-utils",
    "body": [
      "import type { ${1:EntityName} } from './types';",
      "",
      "export function get${1:EntityName}DisplayName(entity: ${1:EntityName}): string {",
      "  return entity.id;",
      "}",
      "",
      "export function isSame${1:EntityName}(a: ${1:EntityName}, b: ${1:EntityName}): boolean {",
      "  return a.id === b.id;",
      "}",
      "",
      "export function filter${1:EntityName}sById(entities: ${1:EntityName}[], ids: string[]): ${1:EntityName}[] {",
      "  return entities.filter(entity => ids.includes(entity.id));",
      "}",
      "$0"
    ],
    "description": "Create FSD entity utility functions"
  },
