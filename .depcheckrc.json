{
    "ignores": [
        "node_modules",
        "dist",
        ".wrangler",
        ".venv",
        "docs",
        "supabase",
        "functions",
        "cloudflare-workers",
        "scripts",
        "tests",
        "public"
    ],
    "ignorePatterns": [
        "**/*.d.ts",
        "**/*.config.*",
        "**/vite-env.d.ts"
    ],
    "ignoreDeps": [
        "autoprefixer",
        "tailwindcss",
        "postcss",
        "vite",
        "vitest",
        "@vitejs/plugin-react",
        "husky",
        "lint-staged",
        "secretlint",
        "@secretlint/secretlint-rule-preset-recommend",
        "@commitlint/cli",
        "@commitlint/config-conventional",
        "prettier",
        "eslint",
        "cspell",
        "tsc-files",
        "typescript",
        "typescript-eslint",
        "@eslint/js",
        "globals",
        "puppeteer",
        "@types/puppeteer",
        "jest",
        "ts-jest",
        "ts-node",
        "jsdom",
        "fast-check",
        "@testing-library/react",
        "@testing-library/dom",
        "@testing-library/jest-dom",
        "@types/jest",
        "concurrently",
        "knip",
        "madge",
        "depcheck",
        "@locator/babel-jsx"
    ]
