# Local Development Environment Variables for Pages Functions
# Copy this file to .dev.vars and fill in your actual values
# DO NOT commit .dev.vars to git!

# ==================== SSO / AUTH CONFIGURATION ====================
# Must match the SSO worker that issued the user's session token


# ==================== SUPABASE CONFIGURATION ====================
# SUPABASE_URL is preferred by Pages Functions;
SUPABASE_URL=https://dpooleduinyyzxgrcwko.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here




# ==================== EMBEDDING WORKER CONFIGURATION ====================
# URL of the embedding worker (standalone Cloudflare Worker on port 9002)
EMBEDDING_API_URL=http://localhost:9002
# Optional API key for authenticating requests to the embedding worker
EMBEDDING_API_KEY=your_embedding_api_key_here


# ==================== EMAIL WORKER CONFIGURATION ====================
# Admin email for event registration notifications
ADMIN_EMAIL=admin@rareminds.in



# ==================== STORAGE / MEDIA CONFIGURATION ====================
# HMAC secret for signing short-lived media access tokens
SIGNING_SECRET=your_signing_secret_here

# ==================== AI SERVICE API KEYS ====================
OPENROUTER_API_KEY=your_openrouter_api_key_here





# ==================== CLOUDFLARE R2 CONFIGURATION (for Storage) ====================
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
CLOUDFLARE_R2_BUCKET_NAME=skill-echosystem
# Optional: public URL for R2 objects (if custom domain is configured)
# CLOUDFLARE_R2_PUBLIC_URL=https://cdn.skillpassport.rareminds.in
