# Copy to .dev.vars for local development
# For staging/production, set these via: wrangler secret put <KEY> --env <staging|production>

ENVIRONMENT=development
RAZORPAY_MODE=test

# Razorpay keys
# local/staging → rzp_test_* keys
# production    → rzp_live_* keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# API keys for Pages Functions → Worker auth
SKILLPASSPORT_API_KEY_DEV=dev-key-skillpassport-xxxxx
SKILLPASSPORT_API_KEY_PROD=prod-key-skillpassport-xxxxx
