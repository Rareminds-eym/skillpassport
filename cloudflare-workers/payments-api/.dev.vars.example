# Copy this file to .dev.vars for local development
# DO NOT commit .dev.vars to version control

# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# RAZORPAY CONFIGURATION
# ============================================================================
# Use RAZORPAY_MODE to toggle between test and live credentials:
#   RAZORPAY_MODE=test  → Uses RAZORPAY_KEY_ID_TEST and RAZORPAY_KEY_SECRET_TEST
#   RAZORPAY_MODE=live  (or unset) → Uses RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET
#
# For local development, use test mode:
#   RAZORPAY_MODE=test
# ============================================================================

# Mode toggle: 'test' or 'live'
RAZORPAY_MODE=test

# Live credentials (used when RAZORPAY_MODE=live or unset)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-live-secret

# Test credentials (used when RAZORPAY_MODE=test)
RAZORPAY_KEY_ID_TEST=rzp_test_xxxxx
RAZORPAY_KEY_SECRET_TEST=your-test-secret

# Optional: Razorpay Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
