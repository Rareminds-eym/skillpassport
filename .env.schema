{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Environment Variables Schema",
  "description": "Schema for validating environment variables across all environments",
  "type": "object",
  "required": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "VITE_EMBEDDING_API_URL",
    "VITE_EMAIL_API_URL",
    "VITE_PAYMENTS_API_URL",
    "VITE_RAZORPAY_KEY_ID",
    "VITE_RAZORPAY_KEY_SECRET",
    "OPENROUTER_API_KEY",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_R2_ACCESS_KEY_ID",
    "CLOUDFLARE_R2_SECRET_ACCESS_KEY",
    "CLOUDFLARE_R2_BUCKET_NAME",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "VITE_LOG_LEVEL"
  ],
  "properties": {
    "VITE_SUPABASE_URL": {
      "type": "string",
      "description": "Supabase project URL",
      "pattern": "^https?://.*",
      "examples": [
        "https://dpooleduinyyzxgrcwko.supabase.co",
        "http://127.0.0.1:54321"
      ]
    },
    "VITE_SUPABASE_ANON_KEY": {
      "type": "string",
      "description": "Supabase anonymous key (public)",
      "minLength": 20
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "type": "string",
      "description": "Supabase service role key (secret)",
      "minLength": 20
    },
    "VITE_EMBEDDING_API_URL": {
      "type": "string",
      "description": "Embedding API endpoint URL",
      "pattern": "^https?://.*"
    },
    "VITE_EMAIL_API_URL": {
      "type": "string",
      "description": "Email API endpoint URL",
      "pattern": "^https?://.*"
    },
    "VITE_PAYMENTS_API_URL": {
      "type": "string",
      "description": "Payments API endpoint URL",
      "pattern": "^https?://.*"
    },
    "VITE_RAZORPAY_KEY_ID": {
      "type": "string",
      "description": "Razorpay key ID (test or live)",
      "pattern": "^rzp_(test|live)_[A-Za-z0-9]+$"
    },
    "VITE_RAZORPAY_KEY_SECRET": {
      "type": "string",
      "description": "Razorpay key secret",
      "minLength": 20
    },
    "OPENROUTER_API_KEY": {
      "type": "string",
      "description": "OpenRouter API key for AI services",
      "pattern": "^sk-or-v1-[A-Za-z0-9]+$"
    },
    "CLOUDFLARE_ACCOUNT_ID": {
      "type": "string",
      "description": "Cloudflare account ID",
      "pattern": "^[a-f0-9]{32}$"
    },
    "CLOUDFLARE_API_TOKEN": {
      "type": "string",
      "description": "Cloudflare API token",
      "minLength": 20
    },
    "CLOUDFLARE_R2_ACCESS_KEY_ID": {
      "type": "string",
      "description": "Cloudflare R2 access key ID",
      "pattern": "^[a-f0-9]{32}$"
    },
    "CLOUDFLARE_R2_SECRET_ACCESS_KEY": {
      "type": "string",
      "description": "Cloudflare R2 secret access key",
      "minLength": 40
    },
    "CLOUDFLARE_R2_BUCKET_NAME": {
      "type": "string",
      "description": "Cloudflare R2 bucket name",
      "pattern": "^[a-z0-9-]+$"
    },
    "AWS_ACCESS_KEY_ID": {
      "type": "string",
      "description": "AWS access key ID for SNS",
      "pattern": "^AKIA[A-Z0-9]{16}$"
    },
    "AWS_SECRET_ACCESS_KEY": {
      "type": "string",
      "description": "AWS secret access key",
      "minLength": 40
    },
    "AWS_REGION": {
      "type": "string",
      "description": "AWS region",
      "enum": [
        "ap-south-1",
        "us-east-1",
        "us-west-2",
        "eu-west-1",
        "ap-southeast-1"
      ]
    },
    "VITE_LOG_LEVEL": {
      "type": "string",
      "description": "Logging level for the application",
      "enum": ["debug", "info", "warn", "error"],
      "default": "debug"
    },
    "NODE_ENV": {
      "type": "string",
      "description": "Node environment",
      "enum": ["development", "staging", "production", "test"]
    },
    "VITE_SSO_URL": {
      "type": "string",
      "description": "SSO Worker base URL for authentication",
      "pattern": "^https?://.*"
    },
    "VITE_AUTH_PROVIDER": {
      "type": "string",
      "description": "Auth provider toggle: 'supabase' (legacy) or 'sso' (new SSO worker)",
      "enum": ["supabase", "sso"],
      "default": "supabase"
    }
  },
  "additionalProperties": false
}
