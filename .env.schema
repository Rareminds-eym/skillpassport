{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Environment Variables Schema",
  "description": "Schema for validating environment variables across all environments",
  "type": "object",
  "required": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY",
    "VITE_SSO_URL",
    "OPENROUTER_API_KEY",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_R2_ACCESS_KEY_ID",
    "CLOUDFLARE_R2_SECRET_ACCESS_KEY",
    "CLOUDFLARE_R2_BUCKET_NAME",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION"
  ],
  "properties": {
    "VITE_SUPABASE_URL": {
      "type": "string",
      "description": "Supabase project URL (frontend-facing)",
      "pattern": "^https?://.*",
      "examples": [
        "https://dpooleduinyyzxgrcwko.supabase.co",
        "http://127.0.0.1:54321"
      ]
    },
    "VITE_SUPABASE_ANON_KEY": {
      "type": "string",
      "description": "Supabase anonymous key (public)",
      "minLength": 20
    },
    "SUPABASE_URL": {
      "type": "string",
      "description": "Supabase project URL (Pages Functions, preferred over VITE_ variant)",
      "pattern": "^https?://.*"
    },
    "SUPABASE_ANON_KEY": {
      "type": "string",
      "description": "Supabase anonymous key (Pages Functions, preferred over VITE_ variant)",
      "minLength": 20
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "type": "string",
      "description": "Supabase service role key (secret)",
      "minLength": 20
    },
    "SUPABASE_JWT_SECRET": {
      "type": "string",
      "description": "Supabase JWT secret for minting Realtime tokens (Dashboard → Settings → API)",
      "minLength": 20
    },
    "VITE_SSO_URL": {
      "type": "string",
      "description": "SSO Worker base URL (frontend-facing fallback for SSO_DOMAIN)",
      "pattern": "^https?://.*"
    },
    "SSO_DOMAIN": {
      "type": "string",
      "description": "SSO Worker base URL (Pages Functions, preferred over VITE_SSO_URL)",
      "pattern": "^https?://.*"
    },
    "VITE_EMBEDDING_API_URL": {
      "type": "string",
      "description": "Embedding API endpoint URL (frontend-facing)",
      "pattern": "^https?://.*"
    },
    "EMBEDDING_API_URL": {
      "type": "string",
      "description": "Embedding worker URL (Pages Functions, preferred over VITE_ variant)",
      "pattern": "^https?://.*"
    },
    "EMBEDDING_API_KEY": {
      "type": "string",
      "description": "Optional API key for authenticating to the embedding worker",
      "minLength": 10
    },
    "VITE_EMAIL_API_URL": {
      "type": "string",
      "description": "Email API endpoint URL (frontend-facing)",
      "pattern": "^https?://.*"
    },
    "EMAIL_WORKER_URL": {
      "type": "string",
      "description": "Email worker URL (Pages Functions)",
      "pattern": "^https?://.*"
    },
    "INTERNAL_API_KEY": {
      "type": "string",
      "description": "API key for authenticating requests to the email worker",
      "minLength": 10
    },
    "ADMIN_EMAIL": {
      "type": "string",
      "description": "Admin email for event registration notifications",
      "format": "email"
    },
    "VITE_PAYMENTS_API_URL": {
      "type": "string",
      "description": "Payments API endpoint URL (frontend-facing fallback for PAYMENTS_API_URL)",
      "pattern": "^https?://.*"
    },
    "PAYMENTS_API_URL": {
      "type": "string",
      "description": "Payment worker URL (Pages Functions, preferred over VITE_ variant)",
      "pattern": "^https?://.*"
    },
    "RAZORPAY_SERVICE_SECRET": {
      "type": "string",
      "description": "Shared HS256 secret for Service JWT signing (must match payment-worker)",
      "minLength": 20
    },
    "VITE_RAZORPAY_KEY_ID": {
      "type": "string",
      "description": "Razorpay key ID (test or live, frontend-facing)",
      "pattern": "^rzp_(test|live)_[A-Za-z0-9]+$"
    },
    "RAZORPAY_KEY_ID": {
      "type": "string",
      "description": "Razorpay key ID injected into create-order responses (Pages Functions)",
      "pattern": "^rzp_(test|live)_[A-Za-z0-9]+$"
    },
    "VITE_RAZORPAY_KEY_SECRET": {
      "type": "string",
      "description": "Razorpay key secret (frontend-facing, only used by payment-worker)",
      "minLength": 20
    },
    "RAZORPAY_KEY_SECRET": {
      "type": "string",
      "description": "Razorpay key secret (only used by payment-worker, not Pages Functions)",
      "minLength": 20
    },
    "APP_URL": {
      "type": "string",
      "description": "Base URL of the application (PDF receipts, email links)",
      "pattern": "^https?://.*"
    },
    "SIGNING_SECRET": {
      "type": "string",
      "description": "HMAC secret for signing short-lived media access tokens",
      "minLength": 20
    },
    "OPENROUTER_API_KEY": {
      "type": "string",
      "description": "OpenRouter API key for AI services",
      "pattern": "^sk-or-v1-[A-Za-z0-9]+$"
    },
    "CLAUDE_API_KEY": {
      "type": "string",
      "description": "Anthropic Claude API key for AI services",
      "minLength": 20
    },
    "VITE_CLAUDE_API_KEY": {
      "type": "string",
      "description": "Anthropic Claude API key (frontend-facing fallback for CLAUDE_API_KEY)",
      "minLength": 20
    },
    "GEMINI_API_KEY": {
      "type": "string",
      "description": "Google Gemini API key for AI services",
      "minLength": 20
    },
    "CLOUDFLARE_ACCOUNT_ID": {
      "type": "string",
      "description": "Cloudflare account ID",
      "pattern": "^[a-f0-9]{32}$"
    },
    "CLOUDFLARE_API_TOKEN": {
      "type": "string",
      "description": "Cloudflare API token",
      "minLength": 20
    },
    "CLOUDFLARE_R2_ACCESS_KEY_ID": {
      "type": "string",
      "description": "Cloudflare R2 access key ID",
      "pattern": "^[a-f0-9]{32}$"
    },
    "CLOUDFLARE_R2_SECRET_ACCESS_KEY": {
      "type": "string",
      "description": "Cloudflare R2 secret access key",
      "minLength": 40
    },
    "CLOUDFLARE_R2_BUCKET_NAME": {
      "type": "string",
      "description": "Cloudflare R2 bucket name",
      "pattern": "^[a-z0-9-]+$"
    },
    "CLOUDFLARE_R2_PUBLIC_URL": {
      "type": "string",
      "description": "Optional public URL for R2 objects (if custom domain is configured)",
      "pattern": "^https?://.*"
    },
    "AWS_ACCESS_KEY_ID": {
      "type": "string",
      "description": "AWS access key ID for SNS",
      "pattern": "^AKIA[A-Z0-9]{16}$"
    },
    "AWS_SECRET_ACCESS_KEY": {
      "type": "string",
      "description": "AWS secret access key",
      "minLength": 40
    },
    "AWS_REGION": {
      "type": "string",
      "description": "AWS region",
      "enum": [
        "ap-south-1",
        "us-east-1",
        "us-west-2",
        "eu-west-1",
        "ap-southeast-1"
      ]
    },
    "OTP_LENGTH": {
      "type": "string",
      "description": "OTP digit length (default: 6)",
      "pattern": "^[4-8]$"
    },
    "OTP_EXPIRY_MINUTES": {
      "type": "string",
      "description": "OTP expiry in minutes (default: 5)",
      "pattern": "^[1-9][0-9]?$"
    },
    "SMS_SENDER_ID": {
      "type": "string",
      "description": "SMS sender ID for OTP messages",
      "pattern": "^[A-Za-z0-9]{2,11}$"
    },
    "VITE_LOG_LEVEL": {
      "type": "string",
      "description": "Logging level for the application",
      "enum": ["debug", "info", "warn", "error"],
      "default": "debug"
    },
    "NODE_ENV": {
      "type": "string",
      "description": "Node environment",
      "enum": ["development", "staging", "production", "test"]
    },
    "VITE_API_BASE_URL": {
      "type": "string",
      "description": "Base URL for API calls (frontend)",
      "pattern": "^https?://.*"
    }
  },
  "additionalProperties": true
}
