{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": " npm run build:dev && concurrently -n \"workers,pages\" -c \"yellow,magenta\" \"npm run workers:dev\" \"npm run pages:dev\"",
    "dev:local": "vite --mode development --port 3000",
    "dev": "vite --mode development --port 3000",
    "dev:staging": "vite --mode staging --port 3000",
    "dev:prod": "vite --port 3000",
    "build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "build:dev": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build --mode development",
    "build:staging": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build --mode staging",
    "build:production": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:staging": "vite preview",
    "preview:production": "vite preview",
    "test": "vitest",
    "test:property": "vitest --run src/__tests__/property/",
    "test:e2e": "bash tests/e2e/run-tests.sh",
    "test:e2e:visible": "HEADLESS=false bash tests/e2e/run-tests.sh",
    "test:e2e:slow": "SLOW_MO=100 bash tests/e2e/run-tests.sh",
    "test:e2e:debug": "HEADLESS=false SLOW_MO=500 bash tests/e2e/run-tests.sh",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "knip": "knip --reporter compact",
    "madge": "madge --circular --extensions ts,tsx,js,jsx src/",
    "depcheck": "depcheck --config .depcheckrc.json",
    "audit": "npm run knip && npm run madge && npm run depcheck",
    "workers:dev": "concurrently -n \"email,embed,pay\" -c \"blue,green,yellow\" \"npm run workers:email\" \"npm run workers:embedding\" \"npm run workers:payments\"",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2024-01-01 --port=8788",
    "pages:build": "npm run build && npm run pages:dev",
    "workers:email": "cd cloudflare-workers/email-api && wrangler dev --port=9001 --inspector-port=9229",
    "workers:embedding": "cd cloudflare-workers/embedding-api && wrangler dev --port=9002 --inspector-port=9230",
    "workers:payments": "cd cloudflare-workers/payments-api && wrangler dev --port=9003 --inspector-port=9232",
    "workers:all": "npm run workers:dev",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "pages:start": "wrangler pages dev dist --compatibility-date=2024-01-01 --port=8788 --live-reload=false",
    "cleanup": "bash scripts/cleanup-ports.sh",
    "stop": "bash scripts/stop-all.sh",
    "dev:all": "npm run cleanup && npm run build && concurrently -n \"frontend,pages,workers,supabase\" -c \"cyan,magenta,yellow,green\" \"npm run dev\" \"npm run pages:dev\" \"npm run workers:dev\" \"npm run supabase:start\"",
    "dev:fast": "bash scripts/start-docker.sh && npm run cleanup && concurrently -n \"supabase,build,frontend,pages,workers\" -c \"green,white,cyan,magenta,yellow\" \"npm run supabase:start\" \"npm run build\" \"npm run dev\" \"sleep 15 && npm run pages:dev\" \"npm run workers:dev\"",
    "dev:auto": "bash scripts/start-docker.sh && npm run dev:fast",
    "start:full": "npm run dev:all",
    "env:validate": "node scripts/validate-env.js validate",
    "env:validate:all": "node scripts/validate-env.js validate:all",
    "env:validate:local": "node scripts/validate-env.js local",
    "env:validate:development": "node scripts/validate-env.js development",
    "env:validate:staging": "node scripts/validate-env.js staging",
    "env:validate:production": "node scripts/validate-env.js production",
    "env:check": "node scripts/validate-env.js check",
    "env:diff": "node scripts/validate-env.js diff",
    "prepare": "husky"
  },
  "scripts-info": {
    "ENVIRONMENT_SETUP": "See .env.schema and .env.example for complete variable documentation",
    "LOCAL_DEVELOPMENT": "npm run dev:local - Uses .env.local with localhost URLs (http://127.0.0.1:54321)",
    "DEVELOPMENT": "npm run dev - Uses .env.development with remote dev environment",
    "STAGING": "npm run build:staging - Uses .env.staging for pre-production testing",
    "PRODUCTION": "npm run build:production - Uses .env.production with LIVE Razorpay keys ⚠️",
    "PREVIEW_COMMANDS": "npm run preview | preview:staging | preview:production",
    "VALIDATION_COMMANDS": {
      "env:validate": "Validate current environment file",
      "env:validate:all": "Validate all environment files (local, development, staging, production)",
      "env:validate:production": "Validate production environment",
      "env:check": "See which variables are set",
      "env:diff": "Compare two environments (usage: npm run env:diff development production)"
    }
  },
