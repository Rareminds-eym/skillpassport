# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit files with real credentials to version control

# ==================== SSO / AUTH CONFIGURATION ====================
# SSO Worker endpoint for authentication (login, signup, JWT verification)
# SSO_DOMAIN: Used by Pages Functions (backend) to verify JWTs via JWKS
# VITE_SSO_URL: Used by frontend auth-client to make auth API calls
VITE_SSO_URL=http://localhost:8787

# ==================== SUPABASE CONFIGURATION ====================
# Supabase database connection (NOT for auth - auth is handled by SSO Worker)
# VITE_* prefix: Used by frontend for direct database queries
# No prefix: Used by Pages Functions for server-side database operations

# Frontend Supabase client (Vite build)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Backend Supabase client (Pages Functions) - same values as above
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: JWT secret for minting Realtime tokens (Dashboard → Settings → API)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ==================== DEVELOPMENT API URLs ====================
# Main API base URL (Cloudflare Pages Functions dev server)
VITE_APP_URL=http://localhost:8788

# Worker API URLs (separate Cloudflare Workers)
# Email Worker: Handles email sending (OTP, notifications, etc.)
VITE_EMAIL_API_URL=http://localhost:9001
EMAIL_API_URL=http://localhost:9001
EMAIL_API_KEY=your_email_api_key_here

# Embedding Worker: Handles vector embeddings for AI features
VITE_EMBEDDING_API_URL=http://localhost:9004
EMBEDDING_API_URL=http://localhost:9004
EMBEDDING_API_KEY=your_embedding_api_key_here

# Payments Worker: Handles Razorpay payment processing
# Note: Razorpay keys are managed by the payment worker and returned in API responses
VITE_PAYMENTS_API_URL=http://localhost:9003
PAYMENTS_API_URL=http://localhost:9003

# ==================== AI SERVICE API KEYS ====================
# OpenRouter: Multi-model AI API gateway
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic Claude: Direct API access
CLAUDE_API_KEY=your_claude_api_key_here
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini: Direct API access
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== CLOUDFLARE CONFIGURATION ====================
# Cloudflare account and R2 storage credentials
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
CLOUDFLARE_R2_BUCKET_NAME=skill-echosystem
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.skillpassport.rareminds.in

# ==================== AWS SNS CONFIGURATION ====================
# AWS credentials for SMS/OTP via SNS
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1

# Optional OTP configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
SMS_SENDER_ID=SKILLPASS

# ==================== ADDITIONAL CONFIGURATION ====================
# Application base URL (for PDF receipts, email links)
APP_URL=https://skillpassport.rareminds.in

# HMAC secret for signing short-lived media access tokens
SIGNING_SECRET=your_signing_secret_here

# Admin email for notifications
ADMIN_EMAIL=admin@rareminds.in

# ==================== ENVIRONMENT ====================
VITE_LOG_LEVEL=debug
