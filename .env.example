# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit files with real credentials to version control

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# API URLs
VITE_EMBEDDING_API_URL=your_embedding_api_url_here
VITE_EMAIL_API_URL=your_email_api_url_here
VITE_PAYMENTS_API_URL=your_payments_api_url_here
VITE_API_BASE_URL=your_api_base_url_here

# Production Environment URLs (fallbacks for localhost fixes)
VITE_PRODUCTION_EMAIL_API_URL=https://skillpassport.rareminds.in/api/email
VITE_PRODUCTION_ORIGINS=https://skillpassport.rareminds.in,https://app.skillpassport.rareminds.in

# Development Environment URLs (for CORS localhost fixes)
VITE_DEV_ORIGIN_1=http://localhost:5173
VITE_DEV_ORIGIN_2=http://localhost:3000
VITE_DEV_ORIGIN_3=http://localhost:8788

# Razorpay Configuration
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
VITE_RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket_name_here

# AWS SNS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1

# Environment (development|staging|production)
NODE_ENV=development

# Logging Level (debug|info|warn|error)
VITE_LOG_LEVEL=debug
